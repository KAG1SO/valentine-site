function celebrate() {
    document.body.style.backgroundColor = "#ff4081";
    document.getElementById("response").innerHTML = "Yay! 🎉 Happy Valentine's Day! 💖";
    alert("Yay! 🎉 Happy Valentine's Day! 💖");
}

function beSad() {
    document.body.style.backgroundColor = "#90a4ae";
    document.getElementById("response").innerHTML = "Oh no... 💔 Maybe next time?";
    alert("Oh no... 💔 Maybe next time?");
}
